# 墨冉AI平台 - 环境配置文件
# ============================
#
# 使用说明：
# 1. 根据部署环境复制对应的配置文件
# 2. 开发环境：config.development.env
# 3. 测试环境：config.testing.env
# 4. 生产环境：config.production.env
#
# 加载方式：
# - Linux/Mac: source config.env && python app.py
# - Windows:  $env:FLASK_ENV="production"; python app.py
#

# ===================
# 通用配置
# ===================

# 应用密钥（生产环境必须修改）
SECRET_KEY=moran-ai-platform-2024-secret-key-change-in-production

# 数据库配置
# SQLite（默认）
DATABASE_PATH=./platform.db

# PostgreSQL（生产环境推荐）
# DATABASE_URL=postgresql://username:password@localhost:5432/moran_ai

# 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# API速率限制（请求/分钟）
RATE_LIMIT=60


# ===================
# 开发环境配置
# ===================
# FLASK_ENV=development
# DEBUG=true
# ALLOW_ORIGINS=*
# RATE_LIMIT=100


# ===================
# 测试环境配置
# ===================
# FLASK_ENV=testing
# DEBUG=true
# ALLOW_ORIGINS=*
# RATE_LIMIT=60


# ===================
# 生产环境配置
# ===================
# FLASK_ENV=production
# DEBUG=false
# ALLOW_ORIGINS=https://your-domain.com,https://www.your-domain.com
# RATE_LIMIT=30
