{
  "_comment": "墨冉AI平台 - 模型配置文件",
  "_description": "此文件定义了所有可用的AI模型配置，支持多环境隔离",
  "_version": "1.0.0",
  
  "_usage": {
    "description": "使用方法",
    "steps": [
      "1. 在数据库的models表中插入配置",
      "2. 或通过管理界面的模型管理功能添加",
      "3. 配置会自动进行类型校验和验证"
    ]
  },
  
  "environments": {
