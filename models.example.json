    "testing": {
      "models": [
        {
          "name": "gpt-3.5-turbo",
          "display_name": "GPT-3.5-Turbo（测试）",
          "provider": "openai",
          "base_url": "https://api.openai.com/v1",
          "api_key": "",
          "input_price": 0.0015,
          "output_price": 0.002,
          "status": 1,
          "sort": 10,
          "remark": "测试环境配置"
        }
      ]
    },
    
    "production": {
      "models": []
    }
  },
  
  "model_fields": {
    "name": {
      "type": "string",
      "required": true,
      "description": "模型唯一标识符，用于API调用",
      "example": "gpt-3.5-turbo",
      "constraints": {
        "min_length": 1,
        "max_length": 100,
        "pattern": "^[a-zA-Z0-9_-]+$"
      }
    },
    "display_name": {
      "type": "string",
      "required": false,
      "description": "界面显示的友好名称",
      "example": "GPT-3.5 Turbo",
      "default": "与name相同"
    },
    "provider": {
      "type": "string",
      "required": false,
      "description": "模型提供商",
      "options": ["openai", "deepseek", "doubao", "baidu", "alibaba", "anthropic", "other"],
      "default": "openai"
    },
    "base_url": {
      "type": "string",
      "required": true,
      "description": "API基础地址",
      "example": "https://api.openai.com/v1",
      "constraints": {
        "must_start_with": ["http://", "https://"]
      }
    },
    "api_key": {
      "type": "string",
      "required": true,
      "description": "API密钥",
      "example": "sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "constraints": {
        "min_length": 10
      }
    },
    "input_price": {
      "type": "number",
      "required": true,
      "description": "输入价格（元/千Token）",
      "example": 0.0015,
      "constraints": {
        "min": 0
      }
    },
    "output_price": {
      "type": "number",
      "required": true,
      "description": "输出价格（元/千Token）",
      "example": 0.002,
      "constraints": {
        "min": 0
      }
    },
    "status": {
      "type": "integer",
      "required": false,
      "description": "启用状态",
      "options": [0, 1],
      "default": 1,
      "labels": {
        "0": "禁用",
        "1": "启用"
      }
    },
    "sort": {
      "type": "integer",
      "required": false,
      "description": "排序权重，数字越小越靠前",
      "example": 10,
      "constraints": {
        "min": 0
      },
      "default": 10
    },
    "remark": {
      "type": "string",
      "required": false,
      "description": "备注信息",
      "example": "此模型仅在工作时间可用"
    }
  },
  
  "provider_examples": {
    "openai": {
